{
  "compilerOptions": {
    // Output
    "rootDir": ".",
    "outDir": "./dist",
    // Module system — Node16/NodeNext for proper ESM support
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    // Node types
    "lib": [
      "ES2022"
    ],
    "types": [
      "node"
    ],
    // Emit
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    // Strict checks
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // Misc
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": [
    "*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}